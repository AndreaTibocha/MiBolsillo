<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/lblTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo Movimiento"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A365D"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/etDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descripción (ej. Almuerzo)"
        android:inputType="text"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etValor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Valor ($)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rgTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp"
        android:checkedButton="@id/rbIngreso">

        <RadioButton
            android:id="@+id/rbIngreso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingreso"
            android:layout_marginEnd="24dp" />

        <RadioButton
            android:id="@+id/rbGasto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gasto" />
    </RadioGroup>

    <Button
        android:id="@+id/btnGuardar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar en Bolsillo"
        android:backgroundTint="#3182CE"
        android:textColor="#FFFFFF" />

</LinearLayout>